    //科研成果侧边点击出现蓝色边条
    var my_category = $('.my_cate_id').attr('data-id');
    $(".cate-" + my_category).addClass('blue');

    $('.side-menu-link li').each(function(i){
        if($(this).find('.menu>li.cate_title').length > 0){
            if($(this).find('.menu').is(":hidden")){
                $(this).find('.header>span').addClass('node-btn');
            }else {
                $(this).find('.header>span').addClass('node-btn-open');
            }
        }
    });
    $(".side-menu-link li > .header").click(function () {
        var list = $(this).parent().find(".menu");
        if(list.children('li').length > 0){
            var dis_list = list.css('display');
            $('.side-menu-link li').each(function () {
                if ($(this).find('.menu>li.cate_title').length > 0) {
                    $(this).find("ul.menu").slideUp(400);
                    $(this).find('.header>span').removeClass('node-btn-open').addClass('node-btn');
                } else {
                    $(this).find('.header>span').removeClass('node-btn');
                }
            });
            if (dis_list == 'block') {
                $(this).parent().find("ul.menu").slideUp(400);
                $(this).find("span").removeClass("node-btn-open").addClass('node-btn');
            } else {
                $(this).parent().find("ul.menu").slideDown(400);
                $(this).find("span").removeClass("node-btn").addClass('node-btn-open');
            }
        }
    });
});
