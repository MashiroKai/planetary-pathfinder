$(document).ready(function () {
    //响应式头部js
    $('.btn_1 button').click(function () {
        $('.header-right').slideToggle();
    });

    //点击侧边加上蓝色边条
    $(function () {
        var chg = function (e) {
            var ha = (e && e.target ? e.target.hash : window.location.hash ).replace("#", "");
            var el = ha ? $("li." + ha) : null;
            if (el) {
                $("li.blue").removeClass('blue');
                el.addClass('blue')
            }
        }
        chg();
        $(".cate_title").click(chg);
    });

    //侧边固定
    var scr=$(".main-left .left-menu"); //得到导航对象
    scrollMenu();
    $(window).scroll(function(){
        scrollMenu();
    });
    function scrollMenu() {
        var scrollTop = $(this).scrollTop();
        var scrollHeight = $(document).height();
        var windowHeight = $(this).height();
        if(scrollHeight - windowHeight > 325){
            if(scrollTop>274){
                scr.addClass("fixedsrc");
            }else{
                scr.removeClass("fixedsrc");
            }
        }
    }
